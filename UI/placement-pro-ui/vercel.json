{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/placement-pro-ui/browser",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://placementpro-backend-kor2.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://placementpro-backend-kor2.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
